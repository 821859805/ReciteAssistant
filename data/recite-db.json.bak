                "lastQuality": null,
                "state": 0
              }
            },
            {
              "id": "eaa68c6a-25dd-4558-b12e-ef8932948471",
              "title": "你的兴趣爱好？",
              "content": "（1）羽毛球\n\n（2）打游戏\n\n（3）健身",
              "createdAt": "2026-03-09T05:05:37.307Z",
              "updatedAt": "2026-03-09T05:05:57.681Z",
              "srs": {
                "ease": 2.5,

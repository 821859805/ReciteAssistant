              }
            },
            {
              "id": "0111dafa-5c1e-4a75-82c4-081cb4e6afe7",
              "title": "为什么要设计垃圾回收中的安全区域和安全点？",
              "content": "",
              "createdAt": "2026-03-12T03:09:10.311Z",
              "updatedAt": "2026-03-12T03:09:20.573Z",
              "srs": {
                "ease": 2.5,
                "intervalDays": 0,
                "repetitions": 0,
                "dueAt": "2026-03-12T03:09:10.311Z",
                "lastReviewedAt": null,
                "lapses": 0,
                "lastQuality": null,
                "state": 0
              }
            }
          ]
        },

                "lastReviewedAt": "2026-03-05T01:45:27.130Z",
                "lapses": 0,
                "lastQuality": 2,
                "state": 2
              }
            },
            {
              "id": "5cca9d6d-6ce0-45e5-83f3-6058df3a53c1",
              "title": "查看负载高的进程的命令是？",
              "content": "（1）top\n\n（2）ps -aux",
              "createdAt": "2026-03-01T09:22:00.237Z",
              "updatedAt": "2026-03-05T01:45:32.824Z",
